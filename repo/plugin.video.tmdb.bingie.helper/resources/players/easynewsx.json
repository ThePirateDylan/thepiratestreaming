{
  "name": "EasyNewsX",
  "plugin": "plugin.video.easynewsx",
  "priority": 100,
  "is_resolvable": "true",
  "assert": {
    "play_movie": ["title", "year"],
    "play_episode": ["showname", "season", "episode"],
    "search_movie": ["title", "year"],
    "search_episode": ["showname", "season", "episode"]
  },
  "search_movie": "plugin://plugin.video.easynewsx/searchresults?query={clearname_url}%20{year}",
  "search_episode": "plugin://plugin.video.easynewsx/searchresults?query={name_url}"
}