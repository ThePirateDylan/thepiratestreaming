<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
    <addon id="script.bingie.widgets" name="The Pirate Widgets" version="1.0.3" provider-name="The Pirate Dylan">
    <requires>
		<import addon="xbmc.python" version="3.0.0"/>
        <import addon="xbmc.addon" version="12.0.0"/>
        <import addon="script.module.simplecache" version="2.0.2"/>
		<import addon="script.module.requests" version="2.9.1"/>
        <import addon="script.module.infotagger" version="0.0.4" />
    </requires>

    <extension point="xbmc.python.pluginsource" library="plugin.py">
        <provides>video</provides>
    </extension>
    <extension library="service.py" point="xbmc.service" start="login" />

    <extension point="xbmc.addon.metadata">
        <summary lang="en">The Pirate Widgets</summary>
        <description>Widgets for The Pirate Streaming skin.</description>
		<assets>
            <icon>widgets_icon.png</icon>
            
        </assets>
        <language></language>
        <platform>all</platform>
        <license>GPL v2.0</license>
        <forum></forum>
        <website>https://github.com/ThePirateDylan/thepiratestreaming/tree/main/repo/script.bingie.widgets</website>
        <source></source>
    </extension>
</addon>
